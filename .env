
# Boost cooldown (seconds before next boost can appear)
BOOST_COOLDOWN=12

# How long boost stays active (seconds)
BOOST_DURATION=7

# Countdown before game starts (seconds)
COUNTDOWN_DURATION=5

# How often target moves (seconds)
ZONE_DURATION=4

# Total match duration (seconds)
GAME_DURATION=60

# Vertical position of target (0.90 = near bottom of screen)
TARGET_Y_OFFSET=0.90

# Size of target circle
TARGET_RADIUS=35

# Probability of boost activation per frame (very low = rare boost)
BOOST_CHANCE=0.002

# Score multiplier when combo increases
SCORE_MULTIPLIER_STEP=3

# Maximum combo multiplier bonus allowed
MAX_COMBO_BONUS=3

# Boost score multiplier
BOOST_MULTIPLIER=3

# Time allowed between hits to maintain combo (seconds)
COMBO_TIMEOUT=1.2

# Time after which combo slowly decays (seconds)
COMBO_DECAY_TIME=1.5

# Maximum combo limit before clamping
MAX_COMBO_LIMIT=10

# Combo level after which combo is considered strong streak
COMBO_BREAK_THRESHOLD=3

# YOLO confidence threshold (higher = fewer detections, more strict)
YOLO_CONFIDENCE=0.25